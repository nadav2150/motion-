{
  "name": "videly",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "concurrently -k -n app,tunnel -c blue,magenta \"npm:dev:app\" \"npm:dev:tunnel\"",
    "dev:app": "react-router dev",
    "dev:tunnel": "node scripts/start-tunnel.mjs",
    "dev:local": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@cloudflare/containers": "^0.3.4",
    "@iconify/react": "^6.0.2",
    "@iconify/utils": "^3.1.3",
    "@paddle/paddle-js": "^1.6.4",
    "@paddle/paddle-node-sdk": "^3.8.0",
    "@polar-sh/sdk": "^0.47.1",
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^17.4.2",
    "isbot": "^5.1.36",
    "openai": "^6.37.0",
    "playwright": "^1.60.0",
    "posthog-js": "^1.376.0",
    "posthog-node": "^5.34.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router": "7.15.0",
    "replicate": "^1.0.1",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.0",
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.94.0"
  }
}
