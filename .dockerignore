# Build artifacts — regenerated inside the image.
.react-router
build
node_modules

# Secrets — must NEVER ship inside the image. Set them via
# `wrangler secret put` after deploy (Polar checkout is created server-side, so
# no billing values are baked into the client bundle).
.env
.env.*
*.local

# Local dev / IDE.
.git
.gitignore
.vscode
.idea
.claude
.husky

# Docs + repo metadata.
README.md
DEPLOY.md
*.md
LICENSE

# OS junk.
.DS_Store
Thumbs.db

# CI / coverage / logs.
coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Scripts that don't need to run inside the container.
scripts
