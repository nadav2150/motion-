{
  // Worker-side TypeScript. The React Router app uses the root tsconfig
  // with Node + DOM types. The Worker entry runs in the Cloudflare
  // Workers runtime, so it needs @cloudflare/workers-types instead.
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": ["**/*.ts"]
}
